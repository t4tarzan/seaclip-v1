---
const policies = [
  'PRs require human approval',
  'Cost > $10 requires review',
  'Edge deployments need device-owner sign-off',
];
---

<section id="governance">
  <div class="container">
    <p class="section-label fade-in">GOVERNANCE</p>
    <h2 class="section-title fade-in">You're the board</h2>
    <p class="section-subtitle fade-in">
      Every agent action can require approval. Set policies, review decisions, maintain control.
    </p>

    <div class="gov-content fade-in">
      <div class="gov-approval card">
        <div class="gov-approval__header">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-warning)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 16v-4" />
            <path d="M12 8h.01" />
            <circle cx="12" cy="12" r="10" />
          </svg>
          <span class="gov-approval__label">Approval Request</span>
        </div>

        <div class="gov-approval__body">
          <p class="gov-approval__agent">
            Agent <span class="gov-approval__agent-name">Cloud-Writer</span> requests approval to:
          </p>
          <div class="gov-approval__action">
            Merge PR #38 into <code>main</code>
          </div>
        </div>

        <div class="gov-approval__buttons">
          <button class="gov-btn gov-btn--approve" type="button" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            Approve
          </button>
          <button class="gov-btn gov-btn--reject" type="button" disabled>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
            Reject
          </button>
        </div>
      </div>

      <div class="gov-policies">
        <h3 class="gov-policies__title">Active Policies</h3>
        <ul class="gov-policies__list">
          {policies.map((policy) => (
            <li class="gov-policies__item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
              <span>{policy}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  #governance {
    padding: 6rem 0;
  }

  .gov-content {
    max-width: 560px;
    margin: 3rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .gov-approval {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .gov-approval__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .gov-approval__label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-warning);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .gov-approval__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .gov-approval__agent {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .gov-approval__agent-name {
    font-weight: 600;
    color: var(--color-text);
  }

  .gov-approval__action {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    color: var(--color-text);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.875rem 1.125rem;
    line-height: 1.5;
  }

  .gov-approval__action code {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--color-accent);
    background: rgba(56, 189, 248, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
  }

  .gov-approval__buttons {
    display: flex;
    gap: 0.75rem;
  }

  .gov-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    border: none;
    cursor: default;
    transition: opacity 0.2s ease;
  }

  .gov-btn--approve {
    background: var(--color-success);
    color: var(--color-bg);
  }

  .gov-btn--reject {
    background: #ef4444;
    color: #fff;
  }

  .gov-policies {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gov-policies__title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0;
  }

  .gov-policies__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gov-policies__item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }

  .gov-policies__item svg {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .gov-content {
      max-width: 100%;
    }

    .gov-approval__buttons {
      flex-direction: column;
    }

    .gov-btn {
      justify-content: center;
    }
  }
</style>
