---
const topAgents = [
  { name: 'Cloud-Writer', cost: 45.30, pct: 100 },
  { name: 'Cloud-Analyst', cost: 43.91, pct: 97 },
  { name: 'Local-Analyst', cost: 12.10, pct: 27 },
];
---

<section class="cost-tracking" id="cost-tracking">
  <div class="container">
    <span class="section-label">COST TRACKING</span>
    <h2 class="section-title">Every token has a price tag</h2>
    <p class="section-subtitle">
      Per-run attribution. Know exactly what each agent costs, split by edge vs cloud.
    </p>

    <div class="cost-tracking__dashboard fade-in">
      <!-- Total -->
      <div class="cost-tracking__total">
        <span class="cost-tracking__total-label">Total Monthly Cost</span>
        <span class="cost-tracking__total-value">$127.43</span>
      </div>

      <!-- Cloud vs Edge -->
      <div class="grid grid--2 cost-tracking__split">
        <div class="card cost-tracking__split-card">
          <div class="cost-tracking__split-header">
            <span class="cost-tracking__split-title">Cloud</span>
            <span class="cost-tracking__split-pct">70%</span>
          </div>
          <span class="cost-tracking__split-value">$89.21</span>
          <div class="cost-tracking__minibar">
            <div class="cost-tracking__minibar-fill cost-tracking__minibar-fill--cloud" style="width: 70%" />
          </div>
        </div>
        <div class="card cost-tracking__split-card">
          <div class="cost-tracking__split-header">
            <span class="cost-tracking__split-title">Edge</span>
            <span class="cost-tracking__split-pct">30%</span>
          </div>
          <span class="cost-tracking__split-value">$38.22</span>
          <div class="cost-tracking__minibar">
            <div class="cost-tracking__minibar-fill cost-tracking__minibar-fill--edge" style="width: 30%" />
          </div>
        </div>
      </div>

      <!-- Top Agents -->
      <div class="card cost-tracking__agents">
        <h3 class="cost-tracking__agents-title">Top Agents by Cost</h3>
        <div class="cost-tracking__agents-list">
          {topAgents.map((agent) => (
            <div class="cost-tracking__agent-row">
              <div class="cost-tracking__agent-info">
                <span class="cost-tracking__agent-name">{agent.name}</span>
                <span class="cost-tracking__agent-cost">${agent.cost.toFixed(2)}</span>
              </div>
              <div class="cost-tracking__agent-bar">
                <div
                  class="cost-tracking__agent-bar-fill"
                  style={`width: ${agent.pct}%`}
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cost-tracking {
    padding: 6rem 0;
  }

  .cost-tracking__dashboard {
    margin-top: 3rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .cost-tracking__total {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cost-tracking__total-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cost-tracking__total-value {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--color-accent);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cost-tracking__split {
    gap: 1.5rem;
  }

  .cost-tracking__split-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cost-tracking__split-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cost-tracking__split-title {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .cost-tracking__split-pct {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .cost-tracking__split-value {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    color: var(--color-text);
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .cost-tracking__minibar {
    width: 100%;
    height: 6px;
    background: var(--color-bg);
    border-radius: 3px;
    overflow: hidden;
  }

  .cost-tracking__minibar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width 0.6s ease;
  }

  .cost-tracking__minibar-fill--cloud {
    background: var(--color-accent);
  }

  .cost-tracking__minibar-fill--edge {
    background: var(--color-success);
  }

  .cost-tracking__agents-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .cost-tracking__agents-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cost-tracking__agent-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cost-tracking__agent-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cost-tracking__agent-name {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .cost-tracking__agent-cost {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .cost-tracking__agent-bar {
    width: 100%;
    height: 8px;
    background: var(--color-bg);
    border-radius: 4px;
    overflow: hidden;
  }

  .cost-tracking__agent-bar-fill {
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-secondary));
    transition: width 0.6s ease;
  }

  @media (max-width: 640px) {
    .cost-tracking__total-value {
      font-size: 2.5rem;
    }

    .cost-tracking__split {
      grid-template-columns: 1fr;
    }
  }
</style>
