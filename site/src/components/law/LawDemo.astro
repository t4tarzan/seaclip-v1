<section id="demo">
  <div class="container">
    <p class="section-label fade-in">HOW IT WORKS</p>
    <h2 class="section-title fade-in">See the Pipeline in Action</h2>

    <div class="demo-video fade-in">
      <div class="demo-video__placeholder">
        <span class="demo-video__icon">&#x2696;</span>
        <span class="demo-video__text">Video coming soon</span>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-video {
    margin-top: var(--space-2xl);
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }

  .demo-video__placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    box-shadow:
      0 0 30px rgba(56, 189, 248, 0.15),
      0 0 60px rgba(56, 189, 248, 0.08);
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }

  .demo-video__icon {
    font-size: 3rem;
    opacity: 0.5;
  }

  .demo-video__text {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
