---
const githubUrl = 'https://github.com/t4tarzan/seaclip-v1';
const currentYear = new Date().getFullYear();

const products = [
  { label: 'Mortgage Lite', href: '/mortgage-lite', external: false },
  { label: 'Law Lite', href: '/law-lite', external: false },
  { label: 'Velocity Training', href: 'https://virtualgpt.cloud', external: true },
  { label: 'SeaClaw Agent', href: 'https://seaclawagent.com', external: true },
  { label: 'Dkube.io', href: 'https://dkube.io', external: true },
];

const docs = [
  { label: 'SeaClaw Docs', href: 'https://seaclawagent.com/docs', external: true },
  { label: 'SeaClaw-k8 Docs', href: 'https://seaclawagent.com/platform/docs', external: true },
  { label: 'ClawSwarm Docs', href: 'https://seaclawagent.com/clawswarm/docs', external: true },
];

const openSource = [
  { label: 'SeaClaw GitHub', href: 'https://github.com/t4tarzan/seaclaw', external: true },
  { label: 'SeaClip GitHub', href: githubUrl, external: true },
  { label: 'SeaClip Lite', href: 'https://github.com/t4tarzan/seaclip-lite', external: true },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="footer__logo">SeaClip</span>
        <p class="footer__tagline">On-prem secure orchestration for edge-native AI fleets</p>
      </div>

      <nav class="footer__col" aria-label="Products">
        <h4 class="footer__col-title">Products</h4>
        {products.map((link) => (
          <a href={link.href} {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})} class="footer__link">{link.label}</a>
        ))}
      </nav>

      <nav class="footer__col" aria-label="Documentation">
        <h4 class="footer__col-title">Documentation</h4>
        {docs.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="footer__link">{link.label}</a>
        ))}
      </nav>

      <nav class="footer__col" aria-label="Open Source">
        <h4 class="footer__col-title">Open Source</h4>
        {openSource.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="footer__link">{link.label}</a>
        ))}
      </nav>
    </div>

    <hr class="footer__divider" />

    <div class="footer__meta">
      <span class="footer__meta-item">Built with Astro</span>
      <span class="footer__meta-item">MIT License</span>
      <span class="footer__meta-item">&copy; {currentYear}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-alt);
    padding: 3.5rem 0 2rem;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-3xl, 3rem);
    align-items: start;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .footer__tagline {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    max-width: 28ch;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__col-title {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }

  .footer__link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--color-accent);
  }

  .footer__divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0 1.25rem;
  }

  .footer__meta {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .footer__meta-item {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl, 1.5rem);
    }

    .footer__brand {
      grid-column: 1 / -1;
      align-items: center;
      text-align: center;
    }

    .footer__tagline {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer__col {
      align-items: center;
    }

    .footer__meta {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
  }
</style>
