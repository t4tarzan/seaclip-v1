---
const scenarios = [
  {
    name: 'John Smith',
    loan: 'Purchase — $450K',
    result: 'APPROVED',
    resultClass: 'approved',
    anomalies: 0,
    time: '1m 12s',
    cost: '$0.03',
  },
  {
    name: 'Catherine Vellotti',
    loan: 'Refinance — $680K',
    result: 'FLAGGED',
    resultClass: 'flagged',
    anomalies: 7,
    time: '1m 48s',
    cost: '$0.05',
  },
  {
    name: 'Maria Garcia',
    loan: 'FHA — $320K',
    result: 'CONDITIONAL',
    resultClass: 'conditional',
    anomalies: 2,
    time: '1m 24s',
    cost: '$0.04',
  },
];
---

<section id="demo">
  <div class="container">
    <p class="section-label fade-in">HOW IT WORKS</p>
    <h2 class="section-title fade-in">Three Applications. Four Minutes. $0.12 Total.</h2>

    <div class="demo-layout fade-in">
      <div class="demo-cases">
        {scenarios.map((s) => (
          <div class="demo-case">
            <div class="demo-case__top">
              <div class="demo-case__info">
                <span class="demo-case__name">{s.name}</span>
                <span class="demo-case__loan">{s.loan}</span>
              </div>
              <span class={`demo-case__result demo-case__result--${s.resultClass}`}>{s.result}</span>
            </div>
            <div class="demo-case__stats">
              <span class="demo-case__stat">{s.anomalies} anomalies</span>
              <span class="demo-case__dot"></span>
              <span class="demo-case__stat">{s.time}</span>
              <span class="demo-case__dot"></span>
              <span class="demo-case__stat">{s.cost}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="demo-video">
        <video
          autoplay
          muted
          loop
          playsinline
          controls
          class="demo-video__player"
        >
          <source src="/videos/mortgage-how-it-works.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<style>
  .demo-layout {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-2xl);
    align-items: center;
    margin-top: var(--space-2xl);
  }

  .demo-cases {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .demo-case {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: var(--space-md) var(--space-lg);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .demo-case:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-glow);
  }

  .demo-case__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.375rem;
  }

  .demo-case__info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .demo-case__name {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .demo-case__loan {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  .demo-case__result {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .demo-case__result--approved { color: #4ade80; background: rgba(74, 222, 128, 0.1); }
  .demo-case__result--flagged { color: #f87171; background: rgba(248, 113, 113, 0.1); }
  .demo-case__result--conditional { color: #fbbf24; background: rgba(251, 191, 36, 0.1); }

  .demo-case__stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
  }

  .demo-case__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-muted);
  }

  .demo-video__player {
    width: 100%;
    border-radius: 12px;
    box-shadow:
      0 0 30px rgba(56, 189, 248, 0.15),
      0 0 60px rgba(56, 189, 248, 0.08);
    background: var(--color-bg-alt);
  }

  @media (max-width: 768px) {
    .demo-layout {
      grid-template-columns: 1fr;
    }

    .demo-video {
      order: -1;
    }
  }
</style>
