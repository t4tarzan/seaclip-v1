---
const adapters = [
  {
    name: 'Claude',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 1 7 7c0 3-2 5.5-5 6.5V18h-4v-2.5C7 14.5 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 18v2a2 2 0 0 0 4 0v-2"/></svg>`,
  },
  {
    name: 'Ollama',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><circle cx="9" cy="10" r="1.5"/><circle cx="15" cy="10" r="1.5"/><path d="M9 15c1 1 5 1 6 0"/></svg>`,
  },
  {
    name: 'SeaClaw',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    name: 'Codex',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>`,
  },
  {
    name: 'Process',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8l3 3-3 3"/><line x1="13" y1="14" x2="17" y2="14"/></svg>`,
  },
  {
    name: 'HTTP',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  },
  {
    name: 'Telegram',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22l-4-9-9-4z"/></svg>`,
  },
];
---

<section id="byoa">
  <div class="container">
    <p class="section-label fade-in">EXTENSIBLE</p>
    <h2 class="section-title fade-in">Seven adapters, one protocol</h2>
    <p class="section-subtitle fade-in">
      Connect any AI backend. Cloud or edge, every adapter speaks the same language.
    </p>

    <div class="adapters-row stagger">
      {adapters.map((a) => (
        <div class="adapter-card card">
          <div class="adapter-icon" set:html={a.icon} />
          <span class="adapter-name">{a.name}</span>
        </div>
      ))}
    </div>

    <div class="org-chart fade-in">
      <div class="org-chart-inner">
        <!-- Hub CEO -->
        <div class="org-node org-node--hub">
          <div class="org-node-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3" />
              <path d="M12 2v7" /><path d="M12 15v7" /><path d="M2 12h7" /><path d="M15 12h7" />
            </svg>
          </div>
          <span class="org-node-label">Hub CEO</span>
        </div>

        <!-- Connector lines -->
        <div class="org-lines">
          <div class="org-line org-line--left"></div>
          <div class="org-line org-line--right"></div>
          <div class="org-line org-line--vertical"></div>
        </div>

        <!-- Child nodes -->
        <div class="org-children">
          <div class="org-node org-node--child">
            <div class="org-node-icon org-node-icon--cloud">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
              </svg>
            </div>
            <span class="org-node-label">Cloud Engineers</span>
            <span class="org-node-sub">Claude, Codex, HTTP</span>
          </div>

          <div class="org-node org-node--child">
            <div class="org-node-icon org-node-icon--edge">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="16" height="16" rx="2" />
                <rect x="9" y="9" width="6" height="6" />
                <path d="M15 2v2" /><path d="M15 20v2" /><path d="M2 15h2" /><path d="M20 15h2" />
                <path d="M9 2v2" /><path d="M9 20v2" /><path d="M2 9h2" /><path d="M20 9h2" />
              </svg>
            </div>
            <span class="org-node-label">Spoke Engineers</span>
            <span class="org-node-sub">Ollama, SeaClaw, Process</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .adapters-row {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-3xl);
    flex-wrap: wrap;
    justify-content: center;
  }

  .adapter-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg) var(--space-xl);
    min-width: 110px;
    text-align: center;
  }

  .adapter-icon {
    color: var(--color-accent);
  }

  .adapter-name {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  /* Org Chart */
  .org-chart {
    margin-top: var(--space-4xl);
    display: flex;
    justify-content: center;
  }

  .org-chart-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .org-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .org-node-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
  }

  .org-node--hub .org-node-icon {
    width: 56px;
    height: 56px;
    background: var(--color-accent-glow);
    border-color: var(--color-accent);
  }

  .org-node-icon--cloud {
    color: var(--color-accent);
  }

  .org-node-icon--edge {
    color: var(--color-accent-secondary);
  }

  .org-node-label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .org-node-sub {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Connector lines */
  .org-lines {
    position: relative;
    width: 320px;
    height: 48px;
  }

  .org-line--vertical {
    position: absolute;
    left: 50%;
    top: 0;
    width: 1px;
    height: 16px;
    background: var(--color-border);
  }

  .org-line--left {
    position: absolute;
    top: 16px;
    left: calc(25% - 0.5px);
    width: calc(25% + 1px);
    height: 1px;
    background: var(--color-border);
  }

  .org-line--left::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 1px;
    height: 32px;
    background: var(--color-border);
  }

  .org-line--right {
    position: absolute;
    top: 16px;
    left: 50%;
    width: calc(25% + 1px);
    height: 1px;
    background: var(--color-border);
  }

  .org-line--right::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    width: 1px;
    height: 32px;
    background: var(--color-border);
  }

  .org-children {
    display: flex;
    gap: var(--space-4xl);
    justify-content: center;
  }

  @media (max-width: 768px) {
    .adapters-row {
      gap: var(--space-sm);
    }

    .adapter-card {
      min-width: 90px;
      padding: var(--space-md);
    }

    .org-lines {
      width: 240px;
    }

    .org-children {
      gap: var(--space-2xl);
    }
  }
</style>
