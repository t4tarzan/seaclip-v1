---
const pillars = [
  {
    title: 'Extensible',
    description: 'Seven adapter types. Add your own in minutes. Every integration follows the same protocol.',
    icon: 'puzzle',
  },
  {
    title: 'Adaptable',
    description: 'PGlite for zero-config, PostgreSQL for scale. Local or cloud. Your infrastructure, your rules.',
    icon: 'gear',
  },
  {
    title: 'Open Source',
    description: 'MIT licensed. Fork it, extend it, self-host it. No vendor lock-in, no phone-home.',
    icon: 'code',
  },
];
---

<section id="open-source">
  <div class="container">
    <p class="section-label fade-in">OPEN SOURCE</p>
    <h2 class="section-title fade-in">Built in the open</h2>

    <div class="grid grid--3 stagger oss-grid">
      {pillars.map((pillar) => (
        <div class="card oss-card">
          <div class="oss-icon">
            {pillar.icon === 'puzzle' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 1 0-3.214 3.214c.446.166.855.497.925.968a.979.979 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.404 2.404 0 0 1 1.998 12c0-.617.236-1.234.706-1.704L4.315 8.685a.98.98 0 0 1 .837-.276c.47.07.802.48.968.925a2.501 2.501 0 1 0 3.214-3.214c-.446-.166-.855-.497-.925-.968a.979.979 0 0 1 .276-.837l1.61-1.61a2.404 2.404 0 0 1 1.705-.707c.617 0 1.234.236 1.704.706l1.568 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 1 1 3.237 3.237c-.464.18-.894.527-.967 1.02z" />
              </svg>
            )}
            {pillar.icon === 'gear' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {pillar.icon === 'code' && (
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" />
                <polyline points="8 6 2 12 8 18" />
              </svg>
            )}
          </div>
          <h3 class="oss-title">{pillar.title}</h3>
          <p class="oss-desc">{pillar.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #open-source {
    padding: 6rem 0;
  }

  .oss-grid {
    margin-top: var(--space-3xl, 3rem);
  }

  .oss-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }

  .oss-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md, 8px);
    background: var(--color-accent-glow, rgba(56, 189, 248, 0.1));
    color: var(--color-accent);
  }

  .oss-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text);
    margin: 0;
  }

  .oss-desc {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }
</style>
